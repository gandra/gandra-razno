# ── Application ──────────────────────────────────
ENV=local
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Default User ─────────────────────────────────
DEFAULT_USER_EMAIL=dragan.mijatovic@cramick-it.com
DEFAULT_USER_PASSWORD=topsecret

# ── LLM Defaults ─────────────────────────────────
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# ── BYOK API Keys ────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./gandra_tools.db

# ── Output ────────────────────────────────────────
OUTPUT_DEFAULT_DIR=gandra-output/

# ── Server ────────────────────────────────────────
HOST=0.0.0.0
PORT=8095
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8095
